{
  "name": "@cli2voice/cli2voice",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "cli2voice": "dist/cli.js"
  },
  "files": [
    "dist",
    "integrations"
  ],
  "dependencies": {
    "@cli2voice/dictation-core": "file:../../packages/dictation-core",
    "@cli2voice/mcp-server": "file:../../packages/mcp-server",
    "@cli2voice/voice-core": "file:../../packages/voice-core",
    "@cli2voice/voice-daemon": "file:../../packages/voice-daemon"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --out-dir dist",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "prepack": "rm -rf integrations && cp -R ../../integrations integrations"
  }
}
